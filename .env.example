# CICCAS 环境变量配置
# 复制此文件为 .env 并修改配置

# ==========================================
# MySQL 数据库配置
# ==========================================
MYSQL_ROOT_PASSWORD=CICCAS_2024_Secure
MYSQL_DATABASE=ciccas_db
MYSQL_USER=ciccas_admin
MYSQL_PASSWORD=CICCAS_Admin_2024

# ==========================================
# 应用数据库连接配置
# ==========================================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ciccas_db
DB_USER=ciccas_admin
DB_PASSWORD=CICCAS_Admin_2024

# ==========================================
# Redis 配置
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# Streamlit 配置
# ==========================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ==========================================
# 系统配置
# ==========================================
PYTHONUNBUFFERED=1
PYTHONPATH=/app
TZ=Asia/Shanghai

# ==========================================
# 数据路径配置
# ==========================================
DATA_RAW_PATH=/app/data/raw
DATA_PROCESSED_PATH=/app/data/processed
DATA_BACKUP_PATH=/app/data/backup

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
LOG_PATH=/app/logs
