# MySQL 配置
DB_HOST=mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=cicdb

# 统一所有可能的数据库名变量，防止代码读错
DB_NAME=cicdb
MYSQL_DB=cicdb

# 统一所有可能的用户名和密码变量名，防止代码读错
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_ROOT_PASSWORD=123456

DB_USER=root
DB_PASSWORD=123456

# 额外对齐你代码里残存的旧配置
ciccas_admin=root
CICCAS_Admin_2024=123456

# Redis 配置
REDIS_HOST=redis
REDIS_PASSWORD=CICCAS_Redis_2024
REDIS_PORT=6379

# 应用配置
STREAMLIT_PORT=8501
PYTHONPATH=/app
TZ=Asia/Shanghai

# 资源限制（可根据服务器配置调整）
MYSQL_MEMORY=1G
REDIS_MEMORY=512M
APP_MEMORY=1G
WORKER_MEMORY=1G
NGINX_MEMORY=256M
PHPMYADMIN_MEMORY=512M